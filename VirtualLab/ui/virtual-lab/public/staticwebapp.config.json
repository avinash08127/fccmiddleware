{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.css",
      "/*.js",
      "/*.json",
      "/*.ico",
      "/*.png",
      "/*.svg"
    ]
  },
  "routes": [
    {
      "route": "/assets/config/runtime-config.json",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      }
    }
  ],
  "globalHeaders": {
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "X-Content-Type-Options": "nosniff"
  }
}
