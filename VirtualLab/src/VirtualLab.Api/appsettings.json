{
  "VirtualLab": {
    "Persistence": {
      "Provider": "Sqlite",
      "ConnectionString": "Data Source=virtual-lab.db"
    },
    "Seed": {
      "ApplyOnStartup": true,
      "ResetOnStartup": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
