{
  "VirtualLab": {
    "Persistence": {
      "Provider": "Sqlite",
      "ConnectionString": "__SET_IN_AZURE_CONFIGURATION__"
    },
    "Seed": {
      "ApplyOnStartup": false,
      "ResetOnStartup": false
    },
    "Cors": {
      "AllowedOrigins": []
    },
    "Callbacks": {
      "DispatchBatchSize": 25,
      "WorkerPollIntervalMs": 1000,
      "RequestTimeoutSeconds": 5,
      "MaxRetryCount": 3,
      "RetryDelaysSeconds": [ 2, 10, 30 ]
    }
  }
}
