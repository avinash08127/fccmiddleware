{
  "VirtualLab": {
    "Persistence": {
      "Provider": "Sqlite",
      "ConnectionString": "Data Source=virtual-lab.dev.db"
    },
    "Seed": {
      "ApplyOnStartup": true,
      "ResetOnStartup": false
    },
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:4200"
      ]
    },
    "Callbacks": {
      "DispatchBatchSize": 25,
      "WorkerPollIntervalMs": 1000,
      "RequestTimeoutSeconds": 5,
      "MaxRetryCount": 3,
      "RetryDelaysSeconds": [ 2, 10, 30 ]
    }
  }
}
