<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration — S-006
    https://developer.android.com/training/articles/security-config

    This file:
      1. Prohibits cleartext (HTTP) traffic for all hosts.
      2. Provides a domain-config block for production/staging where OkHttp-level
         certificate pins (delivered via SiteConfig) can be reinforced.

    Bundled APK pins (defence during initial registration / first config poll):
    ─────────────────────────────────────────────────────────────────────────
    To extract a SHA-256 SPKI pin from a certificate:
        openssl x509 -in cert.pem -pubkey -noout \
          | openssl pkey -pubin -outform der \
          | openssl dgst -sha256 -binary \
          | base64

    Update the <pin-set> block and HttpCloudApiClient.BUNDLED_PINS before
    each certificate rotation. Keep at least one backup pin. Update the
    expiration date to 12 months from the new primary certificate's not-before.
-->
<network-security-config>

    <!--
        AS-009: This XML governs Android framework-managed outbound traffic only.
        FCC adapters also talk to devices through direct HTTP clients, so their
        transport rules are enforced in code via FccTransportSecurity instead.
        Loopback cleartext to 127.0.0.1/localhost remains an intentional same-device
        exception for FCC compatibility and simulators; non-loopback FCC endpoints
        must use HTTPS and explicit cleartext LAN URLs are rejected in code.
    -->

    <domain-config cleartextTrafficPermitted="false">
        <pin-set expiration="2027-03-13">
            <pin digest="SHA-256">YLh1dUR9y6Kja30RrAn7JKnbQG/uEtLMkBgFF2Fuihg=</pin>
            <pin digest="SHA-256">Vjs8r4z+80wjNcr1YKepWQboSIRi63WsWXhIMN+eWys=</pin>
        </pin-set>
        <domain includeSubdomains="true">api.fccmiddleware.io</domain>
        <domain includeSubdomains="true">api-staging.fccmiddleware.io</domain>
        <domain includeSubdomains="true">api-dev.fccmiddleware.io</domain>
    </domain-config>

    <!-- Deny cleartext traffic to all other hosts by default -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>
