{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "PreAuthExpiryWorker": {
    "PollIntervalSeconds": 60,
    "BatchSize": 500,
    "ErrorDelaySeconds": 30
  },
  "UnmatchedReconciliationWorker": {
    "PollIntervalSeconds": 60,
    "BatchSize": 500,
    "ErrorDelaySeconds": 30
  },
  "MonitoringSnapshotWorker": {
    "PollIntervalSeconds": 300,
    "ErrorDelaySeconds": 30
  },
  "ArchiveWorker": {
    "PollIntervalSeconds": 3600,
    "ErrorDelaySeconds": 60,
    "TransactionRetentionMonths": 24,
    "AuditRetentionYears": 7,
    "OutboxRetentionDays": 7,
    "DropDetachedPartitionsAfterExport": true
  }
}
