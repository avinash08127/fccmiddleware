{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "PreAuthExpiryWorker": {
    "PollIntervalSeconds": 60,
    "BatchSize": 500,
    "ErrorDelaySeconds": 30
  }
}
