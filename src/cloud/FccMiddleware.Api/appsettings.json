{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "EdgeAgentDefaults": {
    "Rollout": {
      "MinAgentVersion": "1.0.0",
      "LatestAgentVersion": "1.0.0",
      "UpdateUrl": null,
      "LatestReleaseNotes": null,
      "ConfigTtlHours": 24
    }
  },
  "Swagger": {
    "Enabled": false
  }
}
