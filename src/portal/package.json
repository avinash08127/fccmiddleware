{
  "name": "portal",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prebuild": "node scripts/validate-env.js",
    "build": "ng build",
    "build:analyze": "ng build --source-map --named-chunks && source-map-explorer dist/portal/browser/*.js --html dist/portal/bundle-report.html",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\"",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "e2e": "cypress run --browser chrome",
    "e2e:ci": "cypress run --browser chrome --headless"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@azure/msal-angular": "^5.1.1",
    "@azure/msal-browser": "^5.4.0",
    "@primeng/themes": "^20.4.0",
    "chart.js": "^4.5.1",
    "primeicons": "^7.0.0",
    "primeng": "^20.4.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^20.0.0",
    "@angular/build": "^20.3.1",
    "@angular/cli": "^20.3.1",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "@types/qrcode": "^1.5.6",
    "angular-eslint": "^20.0.0",
    "cypress": "^15.11.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.0.0",
    "source-map-explorer": "^2.5.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.0.0"
  }
}
