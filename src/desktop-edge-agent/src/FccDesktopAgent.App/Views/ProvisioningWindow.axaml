<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FccDesktopAgent.App.Views.ProvisioningWindow"
        Title="Puma Energy — FCC Agent Setup"
        Width="600"
        Height="580"
        MinWidth="500"
        MinHeight="520"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="Auto,*,Auto" Margin="28">

    <!-- Header with step indicator -->
    <StackPanel Grid.Row="0" Margin="0,0,0,20">
      <TextBlock Text="Puma Energy FCC Agent Setup"
                 FontSize="22"
                 FontWeight="SemiBold"
                 Margin="0,0,0,8" />

      <!-- Step indicator bar -->
      <Grid ColumnDefinitions="*,*,*,*" Margin="0,4,0,0">
        <StackPanel x:Name="StepIndicator1" Spacing="2">
          <Border Height="3" CornerRadius="2" Background="#3B82F6" />
          <TextBlock Text="1. Welcome" FontSize="11" HorizontalAlignment="Center" Opacity="0.7" />
        </StackPanel>
        <StackPanel x:Name="StepIndicator2" Spacing="2">
          <Border x:Name="StepBar2" Height="3" CornerRadius="2" Background="#D1D5DB" />
          <TextBlock Text="2. Registration" FontSize="11" HorizontalAlignment="Center" Opacity="0.7" />
        </StackPanel>
        <StackPanel x:Name="StepIndicator3" Spacing="2">
          <Border x:Name="StepBar3" Height="3" CornerRadius="2" Background="#D1D5DB" />
          <TextBlock Text="3. Test" FontSize="11" HorizontalAlignment="Center" Opacity="0.7" />
        </StackPanel>
        <StackPanel x:Name="StepIndicator4" Spacing="2">
          <Border x:Name="StepBar4" Height="3" CornerRadius="2" Background="#D1D5DB" />
          <TextBlock Text="4. Complete" FontSize="11" HorizontalAlignment="Center" Opacity="0.7" />
        </StackPanel>
      </Grid>
    </StackPanel>

    <!-- Step content area (panels swapped by code-behind) -->
    <Grid Grid.Row="1">

      <!-- ═══ Step 1: Welcome + Choose method ═══ -->
      <StackPanel x:Name="Step1Panel" Spacing="16">
        <TextBlock Text="Welcome! Let's set up your edge agent."
                   FontSize="15" TextWrapping="Wrap" />
        <TextBlock Text="Choose how you'd like to register this device:"
                   Opacity="0.6" TextWrapping="Wrap" />

        <!-- Registration code option -->
        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="16" BorderThickness="1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                Cursor="Hand">
          <RadioButton x:Name="RadioCodeMethod"
                       GroupName="RegMethod"
                       IsChecked="True">
            <StackPanel Spacing="4">
              <TextBlock Text="Registration Code" FontWeight="SemiBold" FontSize="14" />
              <TextBlock Text="Enter a one-time provisioning token from the admin portal. The agent will register with the cloud automatically."
                         TextWrapping="Wrap" Opacity="0.6" FontSize="12" />
            </StackPanel>
          </RadioButton>
        </Border>

        <!-- Manual config option -->
        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="16" BorderThickness="1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                Cursor="Hand">
          <RadioButton x:Name="RadioManualMethod"
                       GroupName="RegMethod">
            <StackPanel Spacing="4">
              <TextBlock Text="Manual Configuration" FontWeight="SemiBold" FontSize="14" />
              <TextBlock Text="Enter the cloud URL, site code, and FCC connection details manually. Use this if you have the configuration details but no provisioning token."
                         TextWrapping="Wrap" Opacity="0.6" FontSize="12" />
            </StackPanel>
          </RadioButton>
        </Border>
      </StackPanel>

      <!-- ═══ Step 2a: Registration code flow ═══ -->
      <StackPanel x:Name="Step2aPanel" IsVisible="False" Spacing="12">
        <TextBlock Text="Enter Registration Details"
                   FontSize="15" FontWeight="Medium" />
        <TextBlock Text="Provide the cloud URL, site code, and provisioning token from your admin portal."
                   Opacity="0.6" FontSize="12" TextWrapping="Wrap" />

        <StackPanel Spacing="4">
          <TextBlock Text="Environment" FontWeight="Medium" />
          <ComboBox x:Name="EnvComboBox"
                    SelectedIndex="0"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="OnEnvSelectionChanged" />
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="Cloud URL" FontWeight="Medium" />
          <TextBox x:Name="CloudUrlBox"
                   Watermark="https://api.fccmiddleware.io"
                   Text="https://api.fccmiddleware.io" />
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="Site Code" FontWeight="Medium" />
          <TextBox x:Name="SiteCodeBox"
                   Watermark="e.g., SITE-001" />
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="Provisioning Token" FontWeight="Medium" />
          <TextBox x:Name="TokenBox"
                   Watermark="Paste the one-time token from the admin portal"
                   PasswordChar="*" />
        </StackPanel>

        <CheckBox x:Name="ReplaceCheck"
                  Content="Replace existing agent at this site"
                  Margin="0,4,0,0" />

        <!-- Status area -->
        <Border x:Name="RegStatusBorder"
                IsVisible="False"
                CornerRadius="6"
                Padding="12"
                Margin="0,4,0,0">
          <TextBlock x:Name="RegStatusText"
                     TextWrapping="Wrap"
                     FontSize="13" />
        </Border>
      </StackPanel>

      <!-- ═══ Step 2b: Manual configuration flow ═══ -->
      <StackPanel x:Name="Step2bPanel" IsVisible="False" Spacing="12">
        <TextBlock Text="Manual Configuration"
                   FontSize="15" FontWeight="Medium" />
        <TextBlock Text="Enter the connection details for the cloud backend and the station's Forecourt Controller. Optionally provide a provisioning token for cloud registration."
                   Opacity="0.6" FontSize="12" TextWrapping="Wrap" />

        <StackPanel Spacing="4">
          <TextBlock Text="Environment" FontWeight="Medium" />
          <ComboBox x:Name="ManualEnvComboBox"
                    SelectedIndex="0"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="OnManualEnvSelectionChanged" />
        </StackPanel>

        <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,Auto,Auto">
          <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
            <TextBlock Text="Cloud URL" FontWeight="Medium" />
            <TextBox x:Name="ManualCloudUrlBox"
                     Watermark="https://api.fccmiddleware.io"
                     Text="https://api.fccmiddleware.io" />
          </StackPanel>

          <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
            <TextBlock Text="Site Code" FontWeight="Medium" />
            <TextBox x:Name="ManualSiteCodeBox"
                     Watermark="e.g., SITE-001" />
          </StackPanel>

          <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,12,0,0">
            <TextBlock Text="FCC Host Address" FontWeight="Medium" />
            <TextBox x:Name="ManualFccHostBox"
                     Watermark="e.g., 192.168.1.100" />
          </StackPanel>

          <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4" Margin="0,12,0,0">
            <TextBlock Text="FCC Port" FontWeight="Medium" />
            <TextBox x:Name="ManualFccPortBox"
                     Watermark="8080"
                     Text="8080" />
          </StackPanel>

          <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Spacing="4" Margin="0,12,0,0">
            <TextBlock Text="Provisioning Token (optional — enables cloud registration)" FontWeight="Medium" />
            <TextBox x:Name="ManualTokenBox"
                     Watermark="Paste the one-time token from the admin portal (leave blank for offline mode)"
                     PasswordChar="*" />
          </StackPanel>
        </Grid>

        <!-- Status area -->
        <Border x:Name="ManualStatusBorder"
                IsVisible="False"
                CornerRadius="6"
                Padding="12"
                Margin="0,4,0,0">
          <TextBlock x:Name="ManualStatusText"
                     TextWrapping="Wrap"
                     FontSize="13" />
        </Border>
      </StackPanel>

      <!-- ═══ Step 3: Connection test ═══ -->
      <StackPanel x:Name="Step3Panel" IsVisible="False" Spacing="16">
        <TextBlock Text="Connection Test"
                   FontSize="15" FontWeight="Medium" />
        <TextBlock Text="Testing connectivity to the cloud backend and the Forecourt Controller..."
                   Opacity="0.6" FontSize="12" TextWrapping="Wrap" />

        <!-- Cloud test -->
        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="16" BorderThickness="1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock x:Name="CloudTestIcon" Text="..." FontSize="18"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="Cloud Backend" FontWeight="Medium" />
              <TextBlock x:Name="CloudTestDetail" Text="Waiting..." FontSize="12" Opacity="0.6" />
            </StackPanel>
            <TextBlock x:Name="CloudTestStatus" Grid.Column="2" Text="Pending"
                       FontSize="12" VerticalAlignment="Center" Opacity="0.6" />
          </Grid>
        </Border>

        <!-- FCC test -->
        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="16" BorderThickness="1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock x:Name="FccTestIcon" Text="..." FontSize="18"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="Forecourt Controller (FCC)" FontWeight="Medium" />
              <TextBlock x:Name="FccTestDetail" Text="Waiting..." FontSize="12" Opacity="0.6" />
            </StackPanel>
            <TextBlock x:Name="FccTestStatus" Grid.Column="2" Text="Pending"
                       FontSize="12" VerticalAlignment="Center" Opacity="0.6" />
          </Grid>
        </Border>

        <!-- Overall status -->
        <Border x:Name="TestOverallBorder"
                IsVisible="False"
                CornerRadius="6"
                Padding="12"
                Margin="0,4,0,0">
          <TextBlock x:Name="TestOverallText"
                     TextWrapping="Wrap"
                     FontSize="13" />
        </Border>
      </StackPanel>

      <!-- ═══ Step 4: Success summary ═══ -->
      <StackPanel x:Name="Step4Panel" IsVisible="False" Spacing="16">
        <TextBlock Text="Setup Complete!"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="#16A34A" />
        <TextBlock Text="Your edge agent is configured and ready to operate."
                   Opacity="0.7" TextWrapping="Wrap" />

        <!-- Summary card -->
        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="20" BorderThickness="1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
          <StackPanel Spacing="8">
            <TextBlock Text="Registration Summary" FontWeight="SemiBold" FontSize="14" Opacity="0.7" />
            <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,4,0,0">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Device ID:" Opacity="0.6" Margin="0,3" />
              <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SummaryDeviceId" Text="--" Margin="0,3" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Site Code:" Opacity="0.6" Margin="0,3" />
              <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SummarySiteCode" Text="--" Margin="0,3" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Cloud URL:" Opacity="0.6" Margin="0,3" />
              <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SummaryCloudUrl" Text="--" Margin="0,3" />
              <TextBlock Grid.Row="3" Grid.Column="0" Text="FCC Endpoint:" Opacity="0.6" Margin="0,3" />
              <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SummaryFccEndpoint" Text="--" Margin="0,3" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- API Key card -->
        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="20" BorderThickness="1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
          <StackPanel Spacing="8">
            <TextBlock Text="Local API Key (for HHT Configuration)" FontWeight="SemiBold" FontSize="14" Opacity="0.7" />
            <TextBlock Text="Configure your Odoo POS HHTs to use this API key when connecting to the agent's local API."
                       TextWrapping="Wrap" FontSize="12" Opacity="0.6" />
            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
              <TextBox x:Name="ApiKeyDisplay"
                       IsReadOnly="True"
                       FontFamily="Consolas, monospace"
                       FontSize="13" />
              <Button x:Name="CopyApiKeyButton"
                      Grid.Column="1"
                      Content="Copy"
                      Margin="8,0,0,0"
                      Padding="16,6"
                      Click="OnCopyApiKeyClicked" />
            </Grid>
            <TextBlock x:Name="ApiKeyPortHint" Text="" FontSize="11" Opacity="0.5" />
          </StackPanel>
        </Border>
      </StackPanel>

    </Grid>

    <!-- Navigation buttons -->
    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,20,0,0">
      <Button x:Name="BackButton"
              Grid.Column="0"
              Content="Back"
              IsVisible="False"
              Click="OnBackClicked"
              MinWidth="100"
              HorizontalContentAlignment="Center" />

      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
        <Button x:Name="NextButton"
                Content="Next"
                Classes="accent"
                Click="OnNextClicked"
                MinWidth="140"
                HorizontalContentAlignment="Center" />
      </StackPanel>
    </Grid>

  </Grid>

</Window>
