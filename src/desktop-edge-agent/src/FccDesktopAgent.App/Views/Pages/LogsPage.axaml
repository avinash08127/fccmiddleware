<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FccDesktopAgent.App.Views.Pages.LogsPage"
             x:CompileBindings="False">

  <Grid RowDefinitions="Auto,Auto,*" Margin="24">

    <!-- Header -->
    <TextBlock Grid.Row="0" Text="Audit Logs" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,16" />

    <!-- Filters -->
    <Border Grid.Row="1"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8" Padding="16" Margin="0,0,0,12" BorderThickness="1"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <StackPanel Spacing="4">
          <TextBlock Text="Event Type" FontSize="11" Opacity="0.6" />
          <ComboBox x:Name="EventTypeFilter" Width="160" SelectedIndex="0"
                    SelectionChanged="OnFilterChanged">
            <ComboBoxItem Content="All" />
            <ComboBoxItem Content="ConnectivityChange" />
            <ComboBoxItem Content="FccPoll" />
            <ComboBoxItem Content="CloudUpload" />
            <ComboBoxItem Content="ConfigChange" />
            <ComboBoxItem Content="PreAuth" />
            <ComboBoxItem Content="Registration" />
            <ComboBoxItem Content="Error" />
          </ComboBox>
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="Search" FontSize="11" Opacity="0.6" />
          <TextBox x:Name="SearchBox" Width="200" Watermark="Search logs..."
                   KeyDown="OnSearchKeyDown" />
        </StackPanel>
        <Button Content="Search" VerticalAlignment="Bottom" Padding="16,6"
                Click="OnSearchClicked" />
        <Button Content="Clear" VerticalAlignment="Bottom" Padding="16,6"
                Click="OnClearClicked" />
        <Button Content="Refresh" VerticalAlignment="Bottom" Padding="16,6"
                Click="OnRefreshClicked" />
      </StackPanel>
    </Border>

    <!-- Log entries table -->
    <DataGrid Grid.Row="2"
              x:Name="LogGrid"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              SelectionMode="Single"
              CanUserSortColumns="False"
              GridLinesVisibility="Horizontal">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Time" Binding="{Binding TimestampLocal}" Width="150" />
        <DataGridTextColumn Header="Event Type" Binding="{Binding EventType}" Width="150" />
        <DataGridTextColumn Header="Entity" Binding="{Binding EntityDisplay}" Width="120" />
        <DataGridTextColumn Header="Actor" Binding="{Binding Actor}" Width="100" />
        <DataGridTextColumn Header="Details" Binding="{Binding PayloadPreview}" Width="*" />
      </DataGrid.Columns>
    </DataGrid>

  </Grid>

</UserControl>
